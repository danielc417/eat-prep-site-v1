rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{entryId} {
      allow read: if true;
      allow create: if validLeaderboardEntry();
      allow update: if validLeaderboardEntry()
        && request.resource.data.usernameLower == resource.data.usernameLower
        && request.resource.data.bestStreak >= resource.data.bestStreak;

      function validLeaderboardEntry() {
        return request.resource.data.keys().hasOnly([
          'username',
          'usernameLower',
          'bestStreak',
          'updatedAt'
        ])
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 24
        && request.resource.data.usernameLower is string
        && request.resource.data.bestStreak is int
        && request.resource.data.bestStreak >= 0
        && request.resource.data.bestStreak <= 100000
        && request.resource.data.updatedAt == request.time;
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if validUserDocument();

      function validUserDocument() {
        return request.resource.data.keys().hasOnly([
          'username',
          'usernameLower',
          'passwordHash',
          'avatar',
          'stats',
          'todayStats',
          'missedQuestions',
          'currentStreak',
          'weeklyCorrectWeek',
          'weeklyCorrectCount',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.passwordHash is string
        && request.resource.data.passwordHash.size() == 64
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 24
        && request.resource.data.usernameLower is string
        && request.resource.data.avatar is string
        && request.resource.data.avatar in [
          'assets/avatars/star-of-life.svg',
          'assets/avatars/med-bag.svg',
          'assets/avatars/ambulance.svg',
          'assets/avatars/stethoscope.svg',
          'assets/avatars/clipboard.svg',
          'assets/avatars/lungs.svg',
          'assets/avatars/heart-monitor.svg',
          'assets/avatars/shield.svg'
        ]
        && request.resource.data.stats is map
        && request.resource.data.todayStats is map
        && request.resource.data.missedQuestions is list
        && request.resource.data.missedQuestions.size() <= 300
        && request.resource.data.currentStreak is int
        && request.resource.data.currentStreak >= 0
        && request.resource.data.currentStreak <= 100000
        && request.resource.data.weeklyCorrectWeek is string
        && request.resource.data.weeklyCorrectWeek.size() == 10
        && request.resource.data.weeklyCorrectCount is int
        && request.resource.data.weeklyCorrectCount >= 0
        && request.resource.data.weeklyCorrectCount <= 100000
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      }
    }
  }
}
